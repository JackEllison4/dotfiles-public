#!/bin/bash
# Toggle power menu widget
# Uses secure temporary file approach to avoid TOCTOU race conditions

SOCKET_DIR="${XDG_RUNTIME_DIR:-.cache}"
SOCKET="$SOCKET_DIR/.quickshell-powermenu.sock"

# Create file briefly to signal toggle, then remove it
touch "$SOCKET" 2>/dev/null || {
  # Fallback: use XDG_RUNTIME_DIR or create temp safely
  SOCKET_DIR="${XDG_RUNTIME_DIR:-$HOME/.cache}"
  mkdir -p "$SOCKET_DIR"
  SOCKET="$SOCKET_DIR/.quickshell-powermenu.sock"
  touch "$SOCKET"
}
sleep 0.1
rm -f "$SOCKET" 2>/dev/null
